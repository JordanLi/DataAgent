# 系统元数据库（PostgreSQL，异步驱动）
SYSTEM_DB_URL=postgresql+asyncpg://dataagent:dataagent@localhost:5432/dataagent

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=replace-with-a-long-random-secret

# LLM: openai | claude | deepseek
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# 逗号分隔的前端来源，用于 CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 可选：应用配置 YAML 路径（见 app/config.py）
# CONFIG_YAML=
